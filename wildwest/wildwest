#!/usr/bin/env python3
"""
Wildwest local CLI.

This first executable focuses on provisioning autonomous agent technical
accounts and their systemd services. It is intentionally local-first and uses
Linux primitives directly.
"""

from __future__ import annotations

import argparse
import os
import re
import shlex
import shutil
import subprocess
import sys
from pathlib import Path


AGENT_NAME_RE = re.compile(r"^[a-z][a-z0-9_-]{0,30}$")
DEFAULT_PREFIX = "ww-"
DEFAULT_BASE_DIR = Path("/var/lib/wildwest/agents")
DEFAULT_ENV_DIR = Path("/etc/wildwest/agents")
DEFAULT_RUNTIME_PATH = Path("/usr/local/lib/wildwest/wildwest-agent-runtime")
DEFAULT_SYSTEMD_DIR = Path("/etc/systemd/system")


class CliError(RuntimeError):
    pass


def run(command: list[str], *, dry_run: bool = False, input_text: str | None = None) -> None:
    printable = " ".join(shlex.quote(part) for part in command)
    if dry_run:
        print(f"+ {printable}")
        return

    subprocess.run(command, input=input_text, text=True, check=True)


def require_root(dry_run: bool) -> None:
    if dry_run:
        return
    if os.geteuid() != 0:
        raise CliError("this command must run as root; try sudo ./wildwest create-user ...")


def validate_agent_name(name: str) -> None:
    if not AGENT_NAME_RE.match(name):
        raise CliError("agent name must match ^[a-z][a-z0-9_-]{0,30}$")


def write_file(path: Path, content: str, *, mode: int, dry_run: bool) -> None:
    if dry_run:
        print(f"write {path} mode {oct(mode)}")
        print(content.rstrip())
        return

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    path.chmod(mode)


def install_runtime(path: Path, *, dry_run: bool) -> None:
    content = runtime_script()
    write_file(path, content, mode=0o755, dry_run=dry_run)


def create_user(args: argparse.Namespace) -> None:
    validate_agent_name(args.agent_name)
    require_root(args.dry_run)

    username = f"{args.prefix}{args.agent_name}"
    if len(username) > 32:
        raise CliError(f"generated username {username!r} exceeds common Linux username length limits")

    if args.runtime not in {"codex", "claude"}:
        raise CliError("--runtime must be codex or claude")

    home_dir = args.base_dir / args.agent_name
    workdir = args.workdir or home_dir / "work"
    env_file = args.env_dir / f"{args.agent_name}.env"
    unit_file = args.systemd_dir / f"wildwest-agent-{args.agent_name}.service"

    if shutil.which("systemctl") is None and not args.dry_run:
        raise CliError("systemctl is required")

    user_exists = False
    if not args.dry_run:
        user_exists = subprocess.run(["id", "-u", username], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0

    if user_exists:
        print(f"wildwest: user {username} already exists")
    else:
        run(
            [
                "useradd",
                "--system",
                "--user-group",
                "--create-home",
                "--home-dir",
                str(home_dir),
                "--shell",
                args.shell,
                "--comment",
                f"Wildwest agent {args.agent_name}",
                username,
            ],
            dry_run=args.dry_run,
        )
        run(["passwd", "-l", username], dry_run=args.dry_run)

    for directory, owner_mode in [
        (args.base_dir.parent, None),
        (args.base_dir, None),
        (home_dir, 0o750),
        (home_dir / "inbox", 0o750),
        (home_dir / "outbox", 0o750),
        (home_dir / "run", 0o750),
        (home_dir / "logs", 0o750),
        (workdir, 0o750),
    ]:
        if args.dry_run:
            print(f"mkdir -p {directory}")
            continue
        directory.mkdir(parents=True, exist_ok=True)
        if owner_mode is not None:
            shutil.chown(directory, user=username, group=username)
            directory.chmod(owner_mode)

    install_runtime(args.runtime_path, dry_run=args.dry_run)

    if not env_file.exists() or args.dry_run:
        write_file(
            env_file,
            env_content(
                agent_name=args.agent_name,
                username=username,
                runtime=args.runtime,
                home_dir=home_dir,
                workdir=workdir,
            ),
            mode=0o640,
            dry_run=args.dry_run,
        )
    else:
        print(f"wildwest: preserving existing {env_file}")

    write_file(
        unit_file,
        systemd_unit(
            agent_name=args.agent_name,
            username=username,
            home_dir=home_dir,
            workdir=workdir,
            env_file=env_file,
            runtime_path=args.runtime_path,
        ),
        mode=0o644,
        dry_run=args.dry_run,
    )

    run(["systemctl", "daemon-reload"], dry_run=args.dry_run)
    if args.no_start:
        print(f"wildwest: created service wildwest-agent-{args.agent_name}.service without starting it")
    else:
        run(["systemctl", "enable", "--now", f"wildwest-agent-{args.agent_name}.service"], dry_run=args.dry_run)

    print()
    print("Created Wildwest agent technical account")
    print(f"  agent:   {args.agent_name}")
    print(f"  user:    {username}")
    print(f"  runtime: {args.runtime}")
    print(f"  home:    {home_dir}")
    print(f"  workdir: {workdir}")
    print(f"  env:     {env_file}")
    print(f"  service: wildwest-agent-{args.agent_name}.service")


def env_content(*, agent_name: str, username: str, runtime: str, home_dir: Path, workdir: Path) -> str:
    return f"""# Wildwest agent {agent_name}
WILDWEST_AGENT_NAME={agent_name}
WILDWEST_AGENT_USER={username}
WILDWEST_RUNTIME={runtime}
WILDWEST_HOME={home_dir}
WILDWEST_WORKDIR={workdir}

# Codex non-interactive runtime defaults.
WILDWEST_CODEX_CMD=codex
CODEX_SANDBOX=workspace-write
CODEX_EXTRA_ARGS=

# Claude Code headless runtime defaults.
WILDWEST_CLAUDE_CMD=claude
CLAUDE_EXTRA_ARGS=--bare

# Filesystem spool polling interval.
WILDWEST_POLL_SECONDS=2
"""


def systemd_unit(
    *,
    agent_name: str,
    username: str,
    home_dir: Path,
    workdir: Path,
    env_file: Path,
    runtime_path: Path,
) -> str:
    return f"""[Unit]
Description=Wildwest agent {agent_name}
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={username}
Group={username}
Environment=HOME={home_dir}
EnvironmentFile={env_file}
WorkingDirectory={workdir}
ExecStart={runtime_path}
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths={home_dir} {workdir}
UMask=0077

[Install]
WantedBy=multi-user.target
"""


def runtime_script() -> str:
    return r'''#!/usr/bin/env bash
set -euo pipefail

die() {
  echo "wildwest-agent-runtime: $*" >&2
  exit 1
}

require_env() {
  local name="$1"
  [[ -n "${!name:-}" ]] || die "missing required environment variable: ${name}"
}

shell_words_to_array() {
  local raw="$1"
  local -n out_ref="$2"

  out_ref=()
  if [[ -n "${raw}" ]]; then
    # This supports simple flag lists from root-owned env files.
    # Do not let untrusted users edit WILDWEST_*_EXTRA_ARGS.
    read -r -a out_ref <<<"${raw}"
  fi
}

run_codex() {
  local prompt_file="$1"
  local stdout_file="$2"
  local stderr_file="$3"
  local prompt
  local extra_args=()

  prompt="$(<"${prompt_file}")"
  shell_words_to_array "${CODEX_EXTRA_ARGS:-}" extra_args

  cd "${WILDWEST_WORKDIR}"
  "${WILDWEST_CODEX_CMD:-codex}" exec \
    --sandbox "${CODEX_SANDBOX:-workspace-write}" \
    "${extra_args[@]}" \
    "${prompt}" \
    >"${stdout_file}" 2>"${stderr_file}"
}

run_claude() {
  local prompt_file="$1"
  local stdout_file="$2"
  local stderr_file="$3"
  local prompt
  local extra_args=()

  prompt="$(<"${prompt_file}")"
  shell_words_to_array "${CLAUDE_EXTRA_ARGS:---bare}" extra_args

  cd "${WILDWEST_WORKDIR}"
  "${WILDWEST_CLAUDE_CMD:-claude}" -p \
    "${extra_args[@]}" \
    "${prompt}" \
    >"${stdout_file}" 2>"${stderr_file}"
}

process_job() {
  local prompt_path="$1"
  local job_name
  local job_id
  local running_path
  local result_dir
  local exit_code=0

  job_name="$(basename -- "${prompt_path}")"
  job_id="${job_name%.prompt}"
  running_path="${WILDWEST_HOME}/run/${job_id}.prompt.running"
  result_dir="${WILDWEST_HOME}/outbox/${job_id}"

  if ! mv "${prompt_path}" "${running_path}" 2>/dev/null; then
    return 0
  fi

  mkdir -p "${result_dir}"
  chmod 0700 "${result_dir}"

  {
    echo "agent=${WILDWEST_AGENT_NAME}"
    echo "runtime=${WILDWEST_RUNTIME}"
    echo "workdir=${WILDWEST_WORKDIR}"
    echo "started_at=$(date --iso-8601=seconds)"
  } >"${result_dir}/metadata"

  cp "${running_path}" "${result_dir}/prompt.txt"

  case "${WILDWEST_RUNTIME}" in
    codex)
      run_codex "${running_path}" "${result_dir}/stdout.txt" "${result_dir}/stderr.txt" || exit_code=$?
      ;;
    claude)
      run_claude "${running_path}" "${result_dir}/stdout.txt" "${result_dir}/stderr.txt" || exit_code=$?
      ;;
    *)
      echo "unsupported runtime: ${WILDWEST_RUNTIME}" >"${result_dir}/stderr.txt"
      exit_code=2
      ;;
  esac

  {
    echo "finished_at=$(date --iso-8601=seconds)"
    echo "exit_code=${exit_code}"
  } >>"${result_dir}/metadata"

  echo "${exit_code}" >"${result_dir}/exit_code"
  rm -f "${running_path}"
}

require_env WILDWEST_AGENT_NAME
require_env WILDWEST_RUNTIME
require_env WILDWEST_HOME
require_env WILDWEST_WORKDIR

mkdir -p "${WILDWEST_HOME}/inbox" "${WILDWEST_HOME}/outbox" "${WILDWEST_HOME}/run" "${WILDWEST_HOME}/logs" "${WILDWEST_WORKDIR}"

echo "wildwest-agent-runtime: starting ${WILDWEST_AGENT_NAME} with runtime ${WILDWEST_RUNTIME}" >&2

while true; do
  shopt -s nullglob
  jobs=("${WILDWEST_HOME}/inbox/"*.prompt)
  shopt -u nullglob

  for prompt_path in "${jobs[@]}"; do
    process_job "${prompt_path}"
  done

  sleep "${WILDWEST_POLL_SECONDS:-2}"
done
'''


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="wildwest")
    subparsers = parser.add_subparsers(dest="command", required=True)

    create = subparsers.add_parser("create-user", help="create an agent technical account and service")
    create.add_argument("agent_name")
    create.add_argument("--runtime", choices=["codex", "claude"], default="codex")
    create.add_argument("--workdir", type=Path)
    create.add_argument("--prefix", default=DEFAULT_PREFIX)
    create.add_argument("--shell", default="/bin/bash")
    create.add_argument("--base-dir", type=Path, default=DEFAULT_BASE_DIR)
    create.add_argument("--env-dir", type=Path, default=DEFAULT_ENV_DIR)
    create.add_argument("--runtime-path", type=Path, default=DEFAULT_RUNTIME_PATH)
    create.add_argument("--systemd-dir", type=Path, default=DEFAULT_SYSTEMD_DIR)
    create.add_argument("--no-start", action="store_true")
    create.add_argument("--dry-run", action="store_true")
    create.set_defaults(func=create_user)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    try:
        args.func(args)
    except subprocess.CalledProcessError as exc:
        print(f"wildwest: command failed with exit code {exc.returncode}: {' '.join(exc.cmd)}", file=sys.stderr)
        return exc.returncode
    except CliError as exc:
        print(f"wildwest: {exc}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())

